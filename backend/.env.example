# ─────────────────────────────────────────────
#  Daftar – Production Environment Variables
#  Set all of these in Railway's Variables tab
# ─────────────────────────────────────────────

ENVIRONMENT=production
DEBUG=false

# ── Supabase PostgreSQL ───────────────────────
# From Supabase: Project Settings → Database → Connection string (URI)
# Replace [YOUR-PASSWORD] with your Supabase DB password
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── JWT Secret ────────────────────────────────
# Generate once with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# ── OpenAI ────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Firebase ─────────────────────────────────
# Paste the CONTENTS of your firebase-credentials.json as a single env var
# (Railway supports multi-line env vars)
# OR upload the file and set the path
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ── Unifonic SMS ──────────────────────────────
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=DAFTAR

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=*
